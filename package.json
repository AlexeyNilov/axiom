{
  "name": "axiom",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "db:generate": "DATABASE_URL=file:./dev.db prisma generate",
    "db:push": "node scripts/ensure-sqlite-db.mjs && DATABASE_URL=file:./dev.db prisma db push",
    "db:seed": "DATABASE_URL=file:./dev.db node prisma/seed.mjs",
    "pretest": "npm run db:push",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^20.14.10",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "prisma": "^6.19.3",
    "typescript": "^5.5.3",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
